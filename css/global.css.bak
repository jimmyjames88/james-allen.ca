* {
  margin: 0;
  padding: 0;
  box-sizing: border-box; }

body {
  background-color: #e9e9e9;
  background-image: url(../images/background-zigzag.png);
  background-repeat: repeat-x;
  background-position: -500px 104px;
  font-family: verdana, helvetica, sans-serif;
  overflow-x: hidden; }
  body #main {
    position: relative;
    -webkit-transition: all 0.2s ease;
    -moz-transition: all 0.2s ease;
    -o-transition: all 0.2s ease;
    -ms-transition: all 0.2s ease;
    transition: all 0.2s ease;
    left: 0px; }
    body #main .content {
      width: 960px;
      margin: 0px auto 10px; }
      body #main .content h1, body #main .content h2 {
        margin-left: 6px;
        margin-right: 15px; }
      body #main .content p {
        padding: 0.6em 10px;
        font-size: 13px;
        line-height: 1.5em;
        color: #333; }
    body #main ul li {
      margin-left: 50px;
      font-size: 13px;
      color: #333; }
    body #main .wrap {
      margin-top: 240px; }
    body #main .leftColumn, body #main .rightColumn {
      float: left;
      width: 50%; }

.hide-desktop {
  display: none; }

h1, h2 {
  font-size: 18px;
  font-family: 'Yanone Kaffeesatz', sans-serif;
  font-weight: bold;
  border-bottom: 2px solid #ccc;
  margin-bottom: 10px;
  color: #24252c;
  text-shadow: 1px 1px 1px #fff; }

a {
  text-decoration: none; }
  a:hover h3 {
    color: #24252c; }
  a img {
    border: none; }

h1.title {
  font-size: 96px;
  text-transform: uppercase;
  text-shadow: #fff 1px 1px 0px;
  line-height: 72px;
  border-bottom: none; }

h1 img {
  margin-bottom: 5px; }

.red {
  color: #fe202b; }

h3 {
  color: #f42631;
  text-shadow: 1px 1px 1px #fff;
  font-family: 'Yanone Kaffeesatz', sans-serif; }

.clr {
  clear: both; }

#logo {
  display: block;
  margin-top: 70px;
  float: left; }

#hamburger-button {
  font-size: 18px;
  font-family: 'Yanone Kaffeesatz', sans-serif;
  position: absolute;
  right: 12px;
  top: 16px;
  background-color: #e9e9e9;
  padding: 8px;
  border-radius: 3px; }
  #hamburger-button:after {
    content: '\f0c9';
    font-family: 'FontAwesome'; }

#header {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 900; }
  #header #headerLeft {
    background: url(../images/header-white-90.png);
    position: relative; }
    #header #headerLeft .content {
      width: 480px;
      float: right; }
  #header #headerRight {
    background: url(../images/header-red-95.png); }
  #header #headerLeft, #header #headerRight {
    float: left;
    width: 50%;
    height: 195px; }

#primary-nav {
  float: right;
  margin-top: 24px;
  text-align: right;
  margin-right: 14px; }
  #primary-nav li {
    list-style: none;
    padding: 4px 0px; }
    #primary-nav li.active {
      color: #f42631;
      list-style-type: disc; }
    #primary-nav li:hover {
      list-style: disc; }
      #primary-nav li:hover a {
        color: #f42631; }
    #primary-nav li a {
      font-family: 'Yanone Kaffeesatz', sans-serif;
      font-weight: bold;
      text-decoration: none;
      font-size: 20px;
      text-transform: lowercase;
      color: #24252c; }

#tux {
  background: url(../images/tux-guitar.png);
  width: 412px;
  height: 384px;
  position: relative;
  z-index: 901;
  margin-top: -218px;
  margin-left: 46px;
  -webkit-animation-delay: 0.5s;
  -moz-animation-delay: 0.5s;
  -o-animation-delay: 0.5s;
  -ms-animation-delay: 0.5s;
  animation-delay: 0.5s; }

#circles {
  position: relative;
  z-index: 899;
  white-space: nowrap;
  height: 130px;
  display: none; }
  #circles:after {
    content: "";
    display: block;
    visibility: hidden;
    clear: both;
    height: 0; }
  #circles a {
    position: absolute;
    display: inline-block; }
    #circles a:nth-child(1) {
      left: 0;
      top: 20px; }
      #circles a:nth-child(1) img {
        -webkit-animation-delay: 0.7s;
        -moz-animation-delay: 0.7s;
        -o-animation-delay: 0.7s;
        -ms-animation-delay: 0.7s;
        animation-delay: 0.7s; }
    #circles a:nth-child(2) {
      left: 120px;
      top: -20px; }
      #circles a:nth-child(2) img {
        -webkit-animation-delay: 0.8s;
        -moz-animation-delay: 0.8s;
        -o-animation-delay: 0.8s;
        -ms-animation-delay: 0.8s;
        animation-delay: 0.8s; }
    #circles a:nth-child(3) {
      left: 240px;
      top: 20px; }
      #circles a:nth-child(3) img {
        -webkit-animation-delay: 0.9s;
        -moz-animation-delay: 0.9s;
        -o-animation-delay: 0.9s;
        -ms-animation-delay: 0.9s;
        animation-delay: 0.9s; }
    #circles a:nth-child(4) {
      left: 360px;
      top: -20px; }
      #circles a:nth-child(4) img {
        -webkit-animation-delay: 1s;
        -moz-animation-delay: 1s;
        -o-animation-delay: 1s;
        -ms-animation-delay: 1s;
        animation-delay: 1s; }
  #circles .icon_ecommerce {
    left: 229px;
    top: -11px; }
  #circles .icon_design {
    left: 122px;
    top: -152px; }
  #circles .icon_development {
    left: 95px;
    top: -93px; }

#footer {
  margin-top: 40px;
  background: url(../images/header-red-95.png);
  min-height: 340px;
  font-family: 'Yanone Kaffeesatz', sans-serif;
  font-weight: bold;
  font-size: 15px; }
  #footer a {
    color: #fff;
    text-decoration: none; }
    #footer a:hover {
      color: #000; }
  #footer .content {
    margin: 0 auto;
    width: 960px; }
  #footer .footerQ {
    width: 25%;
    padding-top: 20px;
    float: left; }
    #footer .footerQ:after {
      content: "";
      display: block;
      visibility: hidden;
      height: 0;
      clear: both; }
    #footer .footerQ img, #footer .footerQ div {
      float: left; }
    #footer .footerQ div {
      height: 64px;
      line-height: 64px;
      padding-left: 8px;
      color: #fff;
      font-weight: bold; }
  #footer #copyright {
    text-align: right; }
    #footer #copyright > div {
      float: right;
      margin-right: 10px; }

.portfolioWrap {
  width: 646px;
  margin: 0 auto 40px;
  padding-bottom: 20px;
  border-bottom: 2px solid #ccc; }

.portfolioFrame {
  background: url(../images/portfolio-frame.png);
  width: 646px;
  height: 296px;
  position: relative;
  left: 0;
  top: 0;
  z-index: 801;
  margin: 10px auto; }
  .portfolioFrame a {
    display: block; }
  .portfolioFrame .content {
    margin: 0;
    padding: 0;
    position: relative;
    left: 14px;
    top: 14px;
    z-index: 800;
    background-color: #fff;
    width: 612px;
    height: 261px;
    overflow: hidden; }

div.serviceWrap {
  margin-bottom: 70px; }
  div.serviceWrap img {
    float: right; }

#home-photo {
  float: right;
  width: 240px;
  text-align: center; }

.headline,
.headline img {
  max-width: 100%; }

img.photo {
  padding: 6px 6px 36px 6px;
  background-color: #fff;
  border: 1px solid #ccc;
  box-shadow: #777 8px 8px 18px; }

.sub {
  font-size: 10px; }

.accordionContent {
  width: 100%;
  display: none; }

.accordionHeader {
  cursor: pointer; }
  .accordionHeader:hover {
    text-decoration: underline; }

.accordionClose {
  color: #F42631;
  text-shadow: 1px 1px 1pxm #fff;
  cursor: pointer;
  font-weight: bold;
  display: none; }
